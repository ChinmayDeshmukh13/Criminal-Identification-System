# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# CORS Configuration
CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://127.0.0.1:8000"]

# Face Recognition Configuration
SIMILARITY_THRESHOLD=0.50
FRAME_SKIP=2
CAMERA_SOURCES=[0]

# Database Configuration
DATA_DIR=./data
CRIMINAL_FACES_DIR=./data/criminal_faces
EMBEDDINGS_DIR=./data/embeddings

# Model Configuration
MODEL_DIR=./models
ARCFACE_MODEL=arcface.onnx

# Alert Configuration
ALERT_RETENTION_HOURS=24
MAX_ALERTS=1000

# Security
ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,gif
MAX_UPLOAD_SIZE_MB=10
