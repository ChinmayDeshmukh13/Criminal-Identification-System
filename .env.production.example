# ============================================================
# Criminal Identification System - Extended Configuration Guide
# ============================================================
#
# This file explains all available configuration options.
# Copy .env.example to .env and modify as needed.
#
# NOTE: Never commit .env file to version control!
#

# ============================================================
# APPLICATION ENVIRONMENT SETTINGS
# ============================================================

# Environment mode: 'development' or 'production'
# development: Enables debug mode, hot reload, and verbose logging
# production: Disables debug, uses gunicorn, optimizes for performance
ENVIRONMENT=development

# Enable debug mode: 'true' or 'false'
# true: Shows detailed error messages and stack traces
# false: Hides sensitive information in error responses
DEBUG=true

# Logging level: 'DEBUG', 'INFO', 'WARNING', 'ERROR', 'CRITICAL'
# DEBUG: Most verbose, logs everything
# INFO: General information, startup messages
# WARNING: Only warning and error messages
# ERROR: Only errors
LOG_LEVEL=INFO

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Server host: typically '0.0.0.0' for Docker, '127.0.0.1' for localhost
API_HOST=0.0.0.0

# Server port: 8000 (default), change if port is in use
API_PORT=8000

# Number of worker processes: 
# - Development: 1
# - Production: 2x CPU cores (e.g., 8 for 4-core CPU)
API_WORKERS=4

# Auto-reload on code changes (development only)
# true: Reload server when Python files change
# false: No reload, requires manual restart
API_RELOAD=true

# ============================================================
# CORS (Cross-Origin Resource Sharing) CONFIGURATION
# ============================================================

# Allowed origins for API requests
# Development: Allow all
# Production: Restrict to your domain
# Format: JSON array of URLs
# Examples:
#   All origins: ["*"]
#   Single domain: ["https://your-domain.com"]
#   Multiple: ["https://your-domain.com", "https://app.your-domain.com"]
CORS_ORIGINS=["http://localhost", "http://localhost:3000", "http://127.0.0.1:8000", "http://127.0.0.1"]

# ============================================================
# FACE RECOGNITION CONFIGURATION
# ============================================================

# Face similarity threshold (0.0 - 1.0)
# Lower value = more sensitive, more false positives
# Higher value = stricter, fewer detections
# Recommended: 0.40-0.60
# - 0.40: Very sensitive, many false positives
# - 0.50: Balanced (default)
# - 0.60: Stricter, fewer false positives
SIMILARITY_THRESHOLD=0.50

# Frame skip: Process every Nth frame
# 1: Process every frame (slower, more accurate)
# 2: Process every 2nd frame (30 FPS -> 15 FPS processed)
# 3-4: Process fewer frames (faster, less accurate)
FRAME_SKIP=2

# Camera sources to use
# Format: JSON array of camera indices
# Typically [0] for primary webcam
# Multiple cameras: [0, 1, 2]
CAMERA_SOURCES=[0]

# ============================================================
# DATABASE & FILE PATH CONFIGURATION
# ============================================================

# Root data directory where criminal faces and embeddings are stored
DATA_DIR=./data

# Directory for criminal face images
CRIMINAL_FACES_DIR=./data/criminal_faces

# Directory for face embeddings (numpy files)
EMBEDDINGS_DIR=./data/embeddings

# Directory for pre-trained AI models
MODEL_DIR=./models

# Directory for application logs
LOG_DIR=./logs

# ============================================================
# MODEL CONFIGURATION
# ============================================================

# ArcFace model filename (ONNX format)
# Used for face embedding extraction
ARCFACE_MODEL=arcface.onnx

# ============================================================
# ALERT CONFIGURATION
# ============================================================

# How long to keep alerts in memory (hours)
# Alerts older than this are removed to prevent memory buildup
ALERT_RETENTION_HOURS=24

# Maximum number of alerts to keep in memory
# When exceeded, oldest alerts are removed
MAX_ALERTS=1000

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================

# Allowed file extensions for criminal face uploads
# Comma-separated list, case-insensitive
ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,gif

# Maximum upload file size in megabytes
# Limits file size for criminal face uploads
MAX_UPLOAD_SIZE_MB=10

# ============================================================
# DEPLOYMENT-SPECIFIC SETTINGS
# ============================================================

# For Docker/Production environments, you may also need:
#
# DATABASE_URL=postgresql://user:password@localhost/ifrs
# REDIS_URL=redis://localhost:6379/0
# SECRET_KEY=your-secret-key (if authentication is added)
# SENTRY_DSN=https://your-sentry-dsn (for error tracking)
#

# ============================================================
# EXAMPLES
# ============================================================

# DEVELOPMENT ENVIRONMENT
# ========================
# ENVIRONMENT=development
# DEBUG=true
# LOG_LEVEL=DEBUG
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=1
# API_RELOAD=true
# CORS_ORIGINS=["*"]

# PRODUCTION ENVIRONMENT
# ======================
# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=INFO
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=8
# API_RELOAD=false
# CORS_ORIGINS=["https://your-domain.com"]
# ALERT_RETENTION_HOURS=72
# MAX_ALERTS=5000
